{
  root: {
    type: "Canvas",
    styles: {
      border: "none"
    },
    children: [

      // ── Status ──────────────────────────────────────────────────────────────
      {
        id: "statusText",
        type: "Text",
        anchor: "TopCenter",
        offset: { y: 20 },
        width: 500,
        text: "$$statusMessage",
        styles: {
          fontSize: 32,
          color: "#ffffff",
          textAlign: "center"
        }
      },

      // ── Game field ──────────────────────────────────────────────────────────
      {
        id: "fieldGrid",
        type: "Grid",
        anchor: "Center",
        width: 482,
        height: 322,
        columns: 12,
        spacing: 2,
        styles: {
          backgroundColor: "#0a0a0a",
          padding: "2px",
          borderRadius: "6px",
          boxSizing: "border-box",
          border: "2px solid #333366"
        },
        items: "$$cells",
        element: {
          type: "Box",
          width: 38,
          height: 38,
          styles: {
            backgroundColor: "$$color",
            borderRadius: "4px"
          }
        }
      },

      // ── Bottom controls / legend / restart ─────────────────────────────────
      {
        id: "bottomGroup",
        type: "VStack",
        anchor: "BottomCenter",
        offset: { y: -25 },
        spacing: 10,
        children: [
          {
            id: "restartButton",
            type: "Button",
            width: 180,
            height: 48,
            label: "Restart Level",
            focusable: true,
            styles: {
              fontSize: 22,
              backgroundColor: "#cc4444",
              color: "#ffffff",
              borderRadius: "8px",
              cursor: "pointer"
            },
            focusStyle: {
              backgroundColor: "#aa3333",
              outline: "3px solid #2FA6FF"
            },
            events: {
              click: "onRestartClick"
            }
          },
          {
            id: "controlsHint",
            type: "Text",
            width: 500,
            text: "WASD/Arrows move  |  Q undo",
            styles: {
              fontSize: 14,
              color: "#555577",
              textAlign: "center"
            }
          },
          {
            id: "legendText",
            type: "Text",
            width: 600,
            text: "Blue=You  Brown=Box  DarkRed=Target  Green=Box on Target",
            styles: {
              fontSize: 12,
              color: "#444455",
              textAlign: "center"
            }
          }
        ]
      },

      // ── Win overlay ─────────────────────────────────────────────────────────
      {
        id: "winGroup",
        $if: "showWin",
        then: {
          type: "VStack",
          anchor: "Center",
          spacing: 24,
          children: [
            {
              id: "winText",
              type: "Text",
              width: 500,
              text: "$$statusMessage",
              styles: {
                fontSize: 48,
                color: "#44ff44",
                textAlign: "center",
                textShadow: "0 0 20px #00ff00"
              }
            },
            {
              id: "nextLevelButton",
              type: "Button",
              width: 220,
              height: 64,
              label: "Next Level",
              focusable: true,
              autoFocus: true,
              styles: {
                fontSize: 28,
                backgroundColor: "#4CAF50",
                color: "#ffffff",
                borderRadius: "8px",
                cursor: "pointer"
              },
              focusStyle: {
                backgroundColor: "#45a049",
                outline: "3px solid #2FA6FF"
              },
              events: {
                click: "onNextLevelClick"
              }
            }
          ]
        }
      }
    ]
  }
}
