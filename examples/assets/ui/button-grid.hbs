<Canvas width="1920" height="1080">
  <Grid items="{{ children }}" anchor="TopLeft" pivot="TopLeft" width="1920" height="1080" columns="6" spacing="10">
    <Box width="100" height="100" style="position: relative; border: 1px solid white; color: white">
      test? {{ this.user.name }}
    </Box>
  </Grid>
  <Box anchor="BottomLeft" pivot="BottomLeft" width="{{ test }}%" style="background-color: red" height="100">
    {{ test }}
  </Box>

  <Box anchor="TopRight" pivot="TopRight" offset-y="200" offset-x="-200">
    {{#with children.1.user}}
    test? {{ name }}
    {{/with}}
  </Box>

  <Box anchor="TopRight" pivot="TopRight" offset-y="200" offset-x="-300">
    {{> test user}}
    {{> test }}
  </Box>
</Canvas>
