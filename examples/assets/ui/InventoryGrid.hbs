<Canvas width="1920" height="1080" captureFocus="{{ localPlayer }}">
  <Grid items="{{ items }}" columns="5" spacing="5" anchor="Center" pivot="Center"
        overflow="Scale" maxWidth="fill" maxHeight="fill">
    <Box
      width="150"
      height="150"
      style="border-width: 1px; border-style: solid; border-color: red; color: white"
      focusable="true"
      focusStyle="border-color: blue"
    >
      {{ name }}
    </Box>
  </Grid>
</Canvas>
