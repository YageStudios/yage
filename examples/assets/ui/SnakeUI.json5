{
  root: {
    type: "Canvas",
    styles: {
      border: "none"
    },
    children: [

      // ── Score ───────────────────────────────────────────────────────────────
      {
        id: "scoreText",
        type: "Text",
        anchor: "TopCenter",
        offset: { y: 20 },
        width: 400,
        text: "$$statusMessage",
        styles: {
          fontSize: 36,
          color: "#00ff00",
          textAlign: "center",
          fontFamily: "monospace"
        }
      },

      // ── Game field ──────────────────────────────────────────────────────────
      {
        id: "fieldGrid",
        type: "Grid",
        anchor: "Center",
        width: 502,
        height: 502,
        columns: 20,
        spacing: 1,
        styles: {
          backgroundColor: "#0a0a0a",
          padding: "1px",
          borderRadius: "4px",
          boxSizing: "border-box",
          border: "2px solid #003300"
        },
        items: "$$cells",
        element: {
          type: "Box",
          width: 24,
          height: 24,
          styles: {
            backgroundColor: "$$color",
            borderRadius: "2px"
          }
        }
      },

      // ── Controls hint ───────────────────────────────────────────────────────
      {
        id: "controlsHint",
        type: "Text",
        anchor: "BottomCenter",
        offset: { y: -20 },
        width: 400,
        text: "WASD or Arrow Keys to move",
        styles: {
          fontSize: 14,
          color: "#335533",
          textAlign: "center"
        }
      },

      // ── Game Over overlay ───────────────────────────────────────────────────
      {
        id: "gameOverGroup",
        $if: "showGameOver",
        then: {
          type: "VStack",
          anchor: "Center",
          spacing: 24,
          children: [
            {
              id: "gameOverText",
              type: "Text",
              width: 500,
              text: "$$statusMessage",
              styles: {
                fontSize: 56,
                color: "#ff4444",
                textAlign: "center",
                textShadow: "0 0 20px #ff0000"
              }
            },
            {
              id: "restartButton",
              type: "Button",
              width: 220,
              height: 64,
              label: "Play Again",
              focusable: true,
              autoFocus: true,
              styles: {
                fontSize: 28,
                backgroundColor: "#228B22",
                color: "#ffffff",
                borderRadius: "8px",
                cursor: "pointer"
              },
              focusStyle: {
                backgroundColor: "#1a6e1a",
                outline: "3px solid #2FA6FF"
              },
              events: {
                click: "onRestartClick"
              }
            }
          ]
        }
      }
    ]
  }
}
