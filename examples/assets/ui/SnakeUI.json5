{
  root: {
    type: "box",
    rect: {
      x: "full",
      y: "full"
    },
    config: {
      style: {
        background: "linear-gradient(180deg, #0a1a0a 0%, #000000 100%)",
        border: "none"
      }
    },
    children: {

      // ── Score ───────────────────────────────────────────────────────────────
      scoreText: {
        type: "text",
        rect: {
          x: "center",
          y: "top",
          yOffset: 20,
          width: 400
        },
        config: {
          label: "$$statusMessage",
          fontSize: 36,
          style: {
            color: "#00ff00",
            textAlign: "center",
            fontFamily: "monospace"
          }
        }
      },

      // ── Game field ──────────────────────────────────────────────────────────
      fieldGrid: {
        type: "grid",
        rect: {
          x: "center",
          y: "center",
          width: 502,
          height: 502
        },
        config: {
          gap: "1px",
          style: {
            backgroundColor: "#0a0a0a",
            padding: "1px",
            borderRadius: "4px",
            boxSizing: "border-box",
            border: "2px solid #003300"
          }
        },
        items: "$$cells",
        element: {
          type: "box",
          rect: {
            width: 24,
            height: 24
          },
          config: {
            style: {
              backgroundColor: "$$color",
              borderRadius: "2px"
            }
          }
        }
      },

      // ── Controls hint ───────────────────────────────────────────────────────
      controlsHint: {
        type: "text",
        rect: {
          x: "center",
          y: "bottom",
          yOffset: -20,
          width: 400
        },
        config: {
          label: "WASD or Arrow Keys to move",
          fontSize: 14,
          style: {
            color: "#335533",
            textAlign: "center"
          }
        }
      },

      // ── Game Over overlay ───────────────────────────────────────────────────
      gameOverText: {
        $if: "showGameOver",
        then: {
          type: "text",
          rect: {
            x: "center",
            y: "center",
            yOffset: -60,
            width: 500
          },
          config: {
            label: "$$statusMessage",
            fontSize: 56,
            style: {
              color: "#ff4444",
              textAlign: "center",
              textShadow: "0 0 20px #ff0000"
            }
          }
        }
      },

      restartButton: {
        $if: "showGameOver",
        then: {
          type: "button",
          rect: {
            x: "center",
            y: "center",
            yOffset: 40,
            width: 220,
            height: 64
          },
          config: {
            label: "Play Again",
            fontSize: 28,
            focusable: true,
            autoFocus: true,
            style: {
              backgroundColor: "#228B22",
              color: "#ffffff",
              borderRadius: "8px",
              cursor: "pointer"
            },
            focusStyle: {
              backgroundColor: "#1a6e1a",
              outline: "3px solid #2FA6FF"
            }
          },
          events: {
            click: "onRestartClick"
          }
        }
      }
    }
  }
}