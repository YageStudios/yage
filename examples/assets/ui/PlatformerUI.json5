{
  root: {
    type: "box",
    rect: {
      x: "full",
      y: "full"
    },
    config: {
      style: {
        background: "linear-gradient(180deg, #4A90D9 0%, #87CEEB 100%)",
        border: "none"
      }
    },
    children: {

      // ── Score ───────────────────────────────────────────────────────────────
      statusText: {
        type: "text",
        rect: {
          x: "center",
          y: "top",
          yOffset: 15,
          width: 500
        },
        config: {
          label: "$$statusMessage",
          fontSize: 32,
          style: {
            color: "#ffffff",
            textAlign: "center",
            textShadow: "2px 2px 4px rgba(0,0,0,0.5)"
          }
        }
      },

      // ── Game field ──────────────────────────────────────────────────────────
      fieldGrid: {
        type: "grid",
        rect: {
          x: "center",
          y: "center",
          width: 402,
          height: 602
        },
        config: {
          gap: "0px",
          style: {
            backgroundColor: "#87CEEB",
            padding: "1px",
            boxSizing: "border-box",
            border: "2px solid #4A90D9",
            borderRadius: "4px"
          }
        },
        items: "$$cells",
        element: {
          type: "box",
          rect: {
            width: 20,
            height: 20
          },
          config: {
            style: {
              backgroundColor: "$$color"
            }
          }
        }
      },

      // ── Controls hint ───────────────────────────────────────────────────────
      controlsHint: {
        type: "text",
        rect: {
          x: "center",
          y: "bottom",
          yOffset: -15,
          width: 400
        },
        config: {
          label: "Space / ↑ to flap",
          fontSize: 14,
          style: {
            color: "#335577",
            textAlign: "center"
          }
        }
      },

      // ── Game Over overlay ───────────────────────────────────────────────────
      gameOverText: {
        $if: "showGameOver",
        then: {
          type: "text",
          rect: {
            x: "center",
            y: "center",
            yOffset: -80,
            width: 500
          },
          config: {
            label: "$$statusMessage",
            fontSize: 36,
            style: {
              color: "#ff2222",
              textAlign: "center",
              textShadow: "0 0 10px #ff0000"
            }
          }
        }
      },

      restartButton: {
        $if: "showGameOver",
        then: {
          type: "button",
          rect: {
            x: "center",
            y: "center",
            yOffset: 20,
            width: 220,
            height: 64
          },
          config: {
            label: "Play Again",
            fontSize: 28,
            focusable: true,
            autoFocus: true,
            style: {
              backgroundColor: "#FFD700",
              color: "#333333",
              borderRadius: "8px",
              cursor: "pointer"
            },
            focusStyle: {
              backgroundColor: "#FFC000",
              outline: "3px solid #2FA6FF"
            }
          },
          events: {
            click: "onRestartClick"
          }
        }
      }
    }
  }
}