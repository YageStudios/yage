{
  overlay: {
    type: "Canvas",
    styles: {
      backgroundColor: "rgba(0,0,0,0.9)",
    },
    children: [
      {
        id: "inputDetection",
        $if: "step === 'INPUT_DETECTION'",
        then: {
          type: "VStack",
          anchor: "Center",
          width: 360,
          spacing: 20,
          alignItems: "Center",
          children: [
            {
              id: "title",
              type: "Text",
              text: "{{appName}}",
              width: "fill",
              styles: {
                fontSize: 48,
                textAlign: "center",
              },
            },
            {
              id: "subtitle",
              type: "Text",
              text: "Press Any Button to Join",
              width: "fill",
              styles: {
                fontSize: 24,
                textAlign: "center",
              },
            },
            {
              id: "playerCards",
              type: "VStack",
              width: "fill",
              spacing: 10,
              alignItems: "Center",
              children: [
                {
                  id: "playerCardItems",
                  $each: "inputPlayers",
                  content: [
                    {
                      id: "card",
                      type: "Box",
                      width: 240,
                      height: 60,
                      styles: {
                        border: "2px solid {{color}}",
                        borderRadius: "8px",
                        backgroundColor: "rgba(255,255,255,0.1)",
                      },
                      children: [
                        {
                          id: "label",
                          type: "Text",
                          anchor: "Center",
                          width: "fill",
                          text: "{{label}}",
                          styles: {
                            fontSize: 16,
                            textAlign: "center",
                          },
                        },
                      ],
                    },
                  ],
                },
              ],
            },
            {
              id: "sharedSurfaceActions",
              type: "VStack",
              width: 300,
              spacing: 12,
              alignItems: "Center",
              children: [
                {
                  id: "sharedSurfaceActionItems",
                  $each: "sharedSurfaceActions",
                  content: [
                    {
                      id: "action",
                      type: "Button",
                      width: 300,
                      height: 40,
                      label: "{{label}}",
                      styles: {
                        fontSize: 16,
                        border: "1px solid rgba(255,255,255,0.5)",
                        backgroundColor: "transparent",
                        color: "white",
                        cursor: "pointer",
                      },
                      events: { click: "{{action}}" },
                    },
                  ],
                },
              ],
            },
            {
              id: "startButton",
              $if: "showInputStartButton",
              then: {
                type: "Button",
                width: 300,
                height: 50,
                label: "Start",
                styles: {
                  fontSize: 20,
                  border: "1px solid rgba(255,255,255,0.75)",
                  backgroundColor: "transparent",
                  color: "white",
                  cursor: "pointer",
                },
                events: { click: "confirmInputDetection" },
              },
            },
            {
              id: "continuePrompt",
              $if: "showInputContinuePrompt",
              then: {
                type: "Text",
                width: "fill",
                text: "Press ENTER or START to continue",
                styles: {
                  fontSize: 16,
                  opacity: "0.7",
                  textAlign: "center",
                },
              },
            },
          ],
        },
      },
      {
        id: "mainMenu",
        $if: "step === 'MAIN_MENU'",
        then: {
          type: "VStack",
          anchor: "Center",
          width: 320,
          spacing: 18,
          alignItems: "Center",
          children: [
            {
              id: "title",
              type: "Text",
              text: "{{appName}}",
              width: "fill",
              styles: {
                fontSize: 36,
                textAlign: "center",
              },
            },
            {
              id: "nickname",
              type: "Input",
              width: 300,
              height: 40,
              label: "Enter nickname...",
              value: "{{nickname}}",
              focusable: true,
              styles: {
                padding: "10px",
                fontSize: "18px",
                borderColor: "white",
                backgroundColor: "rgba(255,255,255,0.1)",
                color: "white",
              },
              events: {
                change: "nicknameChange",
                submit: "nicknameChange",
              },
            },
            {
              id: "actions",
              type: "VStack",
              width: 300,
              spacing: 12,
              alignItems: "Center",
              children: [
                {
                  id: "actionItems",
                  $each: "mainMenuActions",
                  content: [
                    {
                      id: "action",
                      type: "Button",
                      width: 300,
                      height: 50,
                      label: "{{label}}",
                      styles: {
                        fontSize: 18,
                        border: "1px solid rgba(255,255,255,0.6)",
                        backgroundColor: "transparent",
                        color: "white",
                        cursor: "pointer",
                      },
                      events: { click: "{{action}}" },
                    },
                  ],
                },
              ],
            },
          ],
        },
      },
      {
        id: "browsing",
        $if: "step === 'BROWSING'",
        then: {
          type: "VStack",
          anchor: "Center",
          width: 640,
          spacing: 16,
          alignItems: "Center",
          children: [
            {
              id: "title",
              type: "Text",
              text: "Join Online Game",
              width: "fill",
              styles: {
                fontSize: 36,
                textAlign: "center",
              },
            },
            {
              id: "emptyState",
              $if: "roomList.length === 0",
              then: {
                type: "Text",
                width: "fill",
                text: "No active rooms found. Be the first to host!",
                styles: {
                  fontSize: 16,
                  opacity: "0.5",
                  textAlign: "center",
                },
              },
            },
            {
              id: "rooms",
              type: "VStack",
              width: 600,
              spacing: 10,
              alignItems: "Center",
              children: [
                {
                  id: "roomItems",
                  $each: "roomList",
                  content: [
                    {
                      id: "room",
                      type: "HStack",
                      width: 600,
                      height: 60,
                      justifyContent: "SpaceBetween",
                      alignItems: "Center",
                      styles: {
                        borderBottom: "1px solid rgba(255,255,255,0.2)",
                      },
                      children: [
                        {
                          id: "roomInfo",
                          type: "VStack",
                          width: 460,
                          spacing: 4,
                          children: [
                            {
                              id: "roomName",
                              type: "Text",
                              width: "fill",
                              text: "{{roomName}}",
                              styles: {
                                fontSize: 18,
                                textAlign: "left",
                              },
                            },
                            {
                              id: "roomMeta",
                              type: "Text",
                              width: "fill",
                              text: "Host: {{hostName}} | {{currentPlayers}}/{{maxPlayers}} players",
                              styles: {
                                fontSize: 14,
                                opacity: "0.7",
                                textAlign: "left",
                              },
                            },
                          ],
                        },
                        {
                          id: "join",
                          type: "Button",
                          width: 80,
                          height: 35,
                          label: "Join",
                          styles: { fontSize: 14 },
                          events: { click: "joinRoom" },
                        },
                      ],
                    },
                  ],
                },
              ],
            },
            {
              id: "browseButtons",
              type: "HStack",
              spacing: 20,
              alignItems: "Center",
              children: [
                {
                  id: "refresh",
                  type: "Button",
                  width: 140,
                  height: 40,
                  label: "Refresh",
                  styles: { fontSize: 16 },
                  events: { click: "refreshRooms" },
                },
                {
                  id: "back",
                  type: "Button",
                  width: 140,
                  height: 40,
                  label: "Back",
                  styles: { fontSize: 16 },
                  events: { click: "showMainMenu" },
                },
              ],
            },
          ],
        },
      },
      {
        id: "lobby",
        $if: "step === 'LOBBY' && lobbyState",
        then: {
          type: "HStack",
          anchor: "Center",
          width: 920,
          spacing: 40,
          alignItems: "Start",
          children: [
            {
              id: "leftColumn",
              type: "VStack",
              width: 420,
              spacing: 12,
              children: [
                {
                  id: "roomName",
                  type: "Text",
                  width: "fill",
                  text: "Room: {{lobbyState.roomName}}",
                  styles: { fontSize: 28, textAlign: "left" },
                },
                {
                  id: "roomId",
                  type: "Text",
                  width: "fill",
                  text: "Room ID: {{roomId}}",
                  styles: { fontSize: 14, opacity: "0.7", textAlign: "left" },
                },
                {
                  id: "playersLabel",
                  type: "Text",
                  width: "fill",
                  text: "Players:",
                  styles: { fontSize: 20, textAlign: "left" },
                },
                {
                  id: "playersBox",
                  type: "Box",
                  width: 400,
                  height: 220,
                  styles: { border: "1px solid white", padding: "10px" },
                  children: [
                    {
                      id: "players",
                      type: "VStack",
                      anchor: "TopLeft",
                      offset: { x: 10, y: 10 },
                      width: 380,
                      spacing: 10,
                      children: [
                        {
                          id: "playerRows",
                          $each: "lobbyPlayers",
                          content: [
                            {
                              id: "row",
                              type: "HStack",
                              width: 380,
                              height: 24,
                              spacing: 12,
                              alignItems: "Center",
                              children: [
                                {
                                  id: "dot",
                                  type: "Box",
                                  width: 10,
                                  height: 10,
                                  styles: {
                                    borderRadius: "50%",
                                    backgroundColor: "{{readyColor}}",
                                  },
                                },
                                {
                                  id: "name",
                                  type: "Text",
                                  width: 320,
                                  text: "{{nameLabel}}",
                                  styles: { fontSize: 16, textAlign: "left" },
                                },
                              ],
                            },
                          ],
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "ready",
                  type: "Button",
                  width: 200,
                  height: 50,
                  label: "{{readyButtonLabel}}",
                  styles: {
                    fontSize: 16,
                    backgroundColor: "{{readyButtonColor}}",
                  },
                  events: { click: "toggleReady" },
                },
                {
                  id: "start",
                  $if: "isHost",
                  then: {
                    type: "Button",
                    width: 200,
                    height: 50,
                    label: "Start Game",
                    styles: { fontSize: 16, opacity: "{{startButtonOpacity}}" },
                    events: { click: "startOnlineGame" },
                  },
                },
                {
                  id: "leave",
                  type: "Button",
                  width: 200,
                  height: 50,
                  label: "Leave Room",
                  styles: { fontSize: 16 },
                  events: { click: "leaveRoom" },
                },
              ],
            },
            {
              id: "chatBox",
              type: "VStack",
              width: 400,
              spacing: 0,
              styles: { border: "1px solid white" },
              children: [
                {
                  id: "messages",
                  type: "Box",
                  width: 400,
                  height: 400,
                  styles: { overflow: "auto", padding: "10px" },
                  children: [
                    {
                      id: "messageList",
                      type: "VStack",
                      anchor: "TopLeft",
                      offset: { x: 10, y: 10 },
                      width: 380,
                      spacing: 8,
                      children: [
                        {
                          id: "messageItems",
                          $each: "chatMessages",
                          content: [
                            {
                              id: "message",
                              type: "Text",
                              width: 380,
                              text: "{{senderName}}: {{text}}",
                              styles: { fontSize: 14, textAlign: "left" },
                            },
                          ],
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "chatInputRow",
                  type: "HStack",
                  width: 400,
                  height: 40,
                  children: [
                    {
                      id: "input",
                      type: "Input",
                      width: 310,
                      height: 40,
                      label: "Type a message...",
                      value: "{{chatDraft}}",
                      focusable: true,
                      styles: {
                        padding: "10px",
                        borderColor: "white",
                        backgroundColor: "rgba(255,255,255,0.1)",
                        color: "white",
                        borderTop: "1px solid white",
                      },
                      events: {
                        change: "chatChange",
                        submit: "chatSubmit",
                      },
                    },
                    {
                      id: "send",
                      type: "Button",
                      width: 90,
                      height: 40,
                      label: "Send",
                      styles: { fontSize: 14, borderTop: "1px solid white" },
                      events: { click: "chatSend" },
                    },
                  ],
                },
              ],
            },
          ],
        },
      },
    ],
  },
}
