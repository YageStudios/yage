{
  overlay: {
    type: "Canvas",
    styles: {
      backgroundColor: "rgba(0,0,0,0.9)",
    },
    children: [
      {
        id: "mainMenu",
        $if: "step === 'MAIN_MENU'",
        then: {
          $breakpoint: {
            landscape: {
              type: "VStack",
              anchor: "Center",
              width: 360,
              spacing: 20,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "{{appName}}",
                  width: "fill",
                  styles: {
                    fontSize: 48,
                    textAlign: "center",
                  },
                },
                {
                  id: "actions",
                  type: "VStack",
                  width: 300,
                  spacing: 12,
                  alignItems: "Center",
                  children: [
                    {
                      id: "actionItems",
                      $each: "mainMenuActions",
                      content: [
                        {
                          id: "action",
                          $ref: "PrimaryButton",
                          width: 300,
                          height: 50,
                          props: {
                            label: "{{label}}",
                          },
                          styles: {
                            fontSize: 18,
                          },
                          events: { click: "{{action}}" },
                        },
                      ],
                    },
                  ],
                },
              ],
            },
            portrait: {
              type: "VStack",
              anchor: "Center",
              width: 700,
              spacing: 30,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "{{appName}}",
                  width: "fill",
                  styles: {
                    fontSize: 72,
                    textAlign: "center",
                  },
                },
                {
                  id: "actions",
                  type: "VStack",
                  width: 600,
                  spacing: 16,
                  alignItems: "Center",
                  children: [
                    {
                      id: "actionItems",
                      $each: "mainMenuActions",
                      content: [
                        {
                          id: "action",
                          $ref: "PrimaryButton",
                          width: 600,
                          height: 70,
                          props: {
                            label: "{{label}}",
                          },
                          styles: {
                            fontSize: 28,
                          },
                          events: { click: "{{action}}" },
                        },
                      ],
                    },
                  ],
                },
              ],
            },
          },
        },
      },
      {
        id: "profileSetup",
        $if: "step === 'PROFILE_SETUP'",
        then: {
          $breakpoint: {
            landscape: {
              type: "VStack",
              anchor: "Center",
              width: 360,
              spacing: 20,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "Enter Nickname",
                  width: "fill",
                  styles: {
                    fontSize: 36,
                    textAlign: "center",
                  },
                },
                {
                  id: "nickname",
                  type: "Input",
                  width: 300,
                  height: 40,
                  label: "Enter nickname...",
                  value: "{{nickname}}",
                  focusable: true,
                  styles: {
                    padding: "10px",
                    fontSize: "18px",
                    borderColor: "white",
                    backgroundColor: "rgba(255,255,255,0.1)",
                    color: "white",
                  },
                  events: {
                    change: "nicknameChange",
                    submit: "submitProfile",
                  },
                },
                {
                  id: "profileButtons",
                  type: "HStack",
                  spacing: 12,
                  alignItems: "Center",
                  children: [
                    {
                      id: "back",
                      $ref: "SecondaryButton",
                      width: 140,
                      height: 50,
                      props: {
                        label: "Back",
                      },
                      styles: {
                        fontSize: 18,
                      },
                      events: { click: "backToMainMenu" },
                    },
                    {
                      id: "continue",
                      $ref: "PrimaryButton",
                      width: 140,
                      height: 50,
                      props: {
                        label: "Continue",
                      },
                      styles: {
                        fontSize: 18,
                        border: "2px solid rgba(255,255,255,0.8)",
                      },
                      events: { click: "submitProfile" },
                    },
                  ],
                },
              ],
            },
            portrait: {
              type: "VStack",
              anchor: "Center",
              width: 700,
              spacing: 30,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "Enter Nickname",
                  width: "fill",
                  styles: {
                    fontSize: 56,
                    textAlign: "center",
                  },
                },
                {
                  id: "nickname",
                  type: "Input",
                  width: 600,
                  height: 60,
                  label: "Enter nickname...",
                  value: "{{nickname}}",
                  focusable: true,
                  styles: {
                    padding: "14px",
                    fontSize: "28px",
                    borderColor: "white",
                    backgroundColor: "rgba(255,255,255,0.1)",
                    color: "white",
                  },
                  events: {
                    change: "nicknameChange",
                    submit: "submitProfile",
                  },
                },
                {
                  id: "profileButtons",
                  type: "HStack",
                  spacing: 20,
                  alignItems: "Center",
                  children: [
                    {
                      id: "back",
                      $ref: "SecondaryButton",
                      width: 280,
                      height: 70,
                      props: {
                        label: "Back",
                      },
                      styles: {
                        fontSize: 28,
                      },
                      events: { click: "backToMainMenu" },
                    },
                    {
                      id: "continue",
                      $ref: "PrimaryButton",
                      width: 280,
                      height: 70,
                      props: {
                        label: "Continue",
                      },
                      styles: {
                        fontSize: 28,
                        border: "2px solid rgba(255,255,255,0.8)",
                      },
                      events: { click: "submitProfile" },
                    },
                  ],
                },
              ],
            },
          },
        },
      },
      {
        id: "inputSetup",
        $if: "step === 'INPUT_SETUP'",
        then: {
          $breakpoint: {
            landscape: {
              type: "VStack",
              anchor: "Center",
              width: 760,
              spacing: 16,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "Player Setup",
                  width: "fill",
                  styles: {
                    fontSize: 36,
                    textAlign: "center",
                  },
                },
                {
                  id: "subtitle",
                  type: "Text",
                  text: "Press ENTER, SPACE, or A to Join",
                  width: "fill",
                  styles: {
                    fontSize: 18,
                    opacity: "0.7",
                    textAlign: "center",
                  },
                },
                {
                  id: "playerSlots",
                  type: "HStack",
                  width: 720,
                  spacing: 12,
                  alignItems: "Center",
                  justifyContent: "Center",
                  children: [
                    {
                      id: "slotItems",
                      $each: "playerSlots",
                      content: [
                        {
                          id: "slot",
                          type: "Box",
                          width: 170,
                          height: 100,
                          styles: {
                            border: "2px solid {{color}}",
                            borderRadius: "8px",
                            backgroundColor: "rgba(255,255,255,0.05)",
                          },
                          children: [
                            {
                              id: "slotLabel",
                              type: "Text",
                              anchor: "Center",
                              width: 150,
                              text: "{{label}}",
                              styles: {
                                fontSize: 12,
                                textAlign: "center",
                              },
                            },
                          ],
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "leaveHint",
                  type: "Text",
                  text: "Press ESC or B to Leave",
                  width: "fill",
                  styles: {
                    fontSize: 14,
                    opacity: "0.5",
                    textAlign: "center",
                  },
                },
                {
                  id: "sharedSurfaceActions",
                  type: "VStack",
                  width: 420,
                  spacing: 12,
                  alignItems: "Center",
                  children: [
                    {
                      id: "sharedSurfaceActionItems",
                      $each: "sharedSurfaceActions",
                      content: [
                        {
                          id: "action",
                          $ref: "SecondaryButton",
                          width: 420,
                          height: 48,
                          props: {
                            label: "{{label}}",
                          },
                          styles: {
                            fontSize: 18,
                            border: "1px solid rgba(255,255,255,0.5)",
                          },
                          events: { click: "{{action}}" },
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "inputSetupButtons",
                  type: "HStack",
                  spacing: 12,
                  alignItems: "Center",
                  children: [
                    {
                      id: "back",
                      $ref: "SecondaryButton",
                      width: 140,
                      height: 50,
                      props: {
                        label: "Back",
                      },
                      styles: {
                        fontSize: 16,
                      },
                      events: { click: "backToMainMenu" },
                    },
                    {
                      id: "continueBtn",
                      $ref: "PrimaryButton",
                      width: 240,
                      height: 50,
                      props: {
                        label: "{{inputSetupContinueLabel}}",
                      },
                      styles: {
                        fontSize: 16,
                        border: "2px solid rgba(255,255,255,0.8)",
                        opacity: "{{meetsMinLocal ? '1' : '0.4'}}",
                      },
                      events: { click: "confirmInputSetup" },
                    },
                  ],
                },
              ],
            },
            portrait: {
              type: "VStack",
              anchor: "Center",
              width: 900,
              spacing: 24,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "Player Setup",
                  width: "fill",
                  styles: {
                    fontSize: 56,
                    textAlign: "center",
                  },
                },
                {
                  id: "subtitle",
                  type: "Text",
                  text: "Press ENTER, SPACE, or A to Join",
                  width: "fill",
                  styles: {
                    fontSize: 28,
                    opacity: "0.7",
                    textAlign: "center",
                  },
                },
                {
                  id: "playerSlots",
                  type: "VStack",
                  width: "fill",
                  spacing: 16,
                  alignItems: "Center",
                  children: [
                    {
                      id: "slotItems",
                      $each: "playerSlots",
                      content: [
                        {
                          id: "slot",
                          type: "Box",
                          width: 500,
                          height: 100,
                          styles: {
                            border: "2px solid {{color}}",
                            borderRadius: "12px",
                            backgroundColor: "rgba(255,255,255,0.05)",
                          },
                          children: [
                            {
                              id: "slotLabel",
                              type: "Text",
                              anchor: "Center",
                              width: 480,
                              text: "{{label}}",
                              styles: {
                                fontSize: 22,
                                textAlign: "center",
                              },
                            },
                          ],
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "leaveHint",
                  type: "Text",
                  text: "Press ESC or B to Leave",
                  width: "fill",
                  styles: {
                    fontSize: 22,
                    opacity: "0.5",
                    textAlign: "center",
                  },
                },
                {
                  id: "sharedSurfaceActions",
                  type: "VStack",
                  width: 600,
                  spacing: 16,
                  alignItems: "Center",
                  children: [
                    {
                      id: "sharedSurfaceActionItems",
                      $each: "sharedSurfaceActions",
                      content: [
                        {
                          id: "action",
                          $ref: "SecondaryButton",
                          width: 600,
                          height: 60,
                          props: {
                            label: "{{label}}",
                          },
                          styles: {
                            fontSize: 24,
                            border: "1px solid rgba(255,255,255,0.5)",
                          },
                          events: { click: "{{action}}" },
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "inputSetupButtons",
                  type: "HStack",
                  spacing: 20,
                  alignItems: "Center",
                  children: [
                    {
                      id: "back",
                      $ref: "SecondaryButton",
                      width: 260,
                      height: 70,
                      props: {
                        label: "Back",
                      },
                      styles: {
                        fontSize: 26,
                      },
                      events: { click: "backToMainMenu" },
                    },
                    {
                      id: "continueBtn",
                      $ref: "PrimaryButton",
                      width: 400,
                      height: 70,
                      props: {
                        label: "{{inputSetupContinueLabel}}",
                      },
                      styles: {
                        fontSize: 26,
                        border: "2px solid rgba(255,255,255,0.8)",
                        opacity: "{{meetsMinLocal ? '1' : '0.4'}}",
                      },
                      events: { click: "confirmInputSetup" },
                    },
                  ],
                },
              ],
            },
          },
        },
      },
      {
        id: "roomBrowser",
        $if: "step === 'ROOM_BROWSER'",
        then: {
          $breakpoint: {
            landscape: {
              type: "VStack",
              anchor: "Center",
              width: 640,
              spacing: 16,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "Join Online Game",
                  width: "fill",
                  styles: {
                    fontSize: 36,
                    textAlign: "center",
                  },
                },
                {
                  id: "emptyState",
                  $if: "roomList.length === 0",
                  then: {
                    type: "Text",
                    width: "fill",
                    text: "No active rooms found. Be the first to host!",
                    styles: {
                      fontSize: 16,
                      opacity: "0.5",
                      textAlign: "center",
                    },
                  },
                },
                {
                  id: "peerJoinCode",
                  $if: "isPeerLobby",
                  then: {
                    type: "HStack",
                    width: 600,
                    spacing: 12,
                    alignItems: "Center",
                    children: [
                      {
                        id: "codeInput",
                        type: "Input",
                        width: 420,
                        height: 40,
                        label: "Enter room code...",
                        value: "{{joinRoomCode}}",
                        focusable: true,
                        styles: {
                          padding: "10px",
                          fontSize: "16px",
                          borderColor: "white",
                          backgroundColor: "rgba(255,255,255,0.1)",
                          color: "white",
                        },
                        events: {
                          change: "joinRoomCodeChange",
                          submit: "submitJoinRoomCode",
                        },
                      },
                      {
                        id: "joinByCode",
                        $ref: "SecondaryButton",
                        width: 168,
                        height: 40,
                        props: {
                          label: "Join By Code",
                        },
                        styles: { fontSize: 16, border: "1px solid rgba(255,255,255,0.5)" },
                        events: { click: "submitJoinRoomCode" },
                      },
                    ],
                  },
                },
                {
                  id: "rooms",
                  type: "VStack",
                  width: 600,
                  spacing: 10,
                  alignItems: "Center",
                  children: [
                    {
                      id: "roomItems",
                      $each: "roomList",
                      content: [
                        {
                          id: "room",
                          type: "HStack",
                          width: 600,
                          height: 60,
                          justifyContent: "SpaceBetween",
                          alignItems: "Center",
                          styles: {
                            borderBottom: "1px solid rgba(255,255,255,0.2)",
                          },
                          children: [
                            {
                              id: "roomInfo",
                              type: "VStack",
                              width: 460,
                              spacing: 4,
                              children: [
                                {
                                  id: "roomName",
                                  type: "Text",
                                  width: "fill",
                                  text: "{{roomName}}",
                                  styles: {
                                    fontSize: 18,
                                    textAlign: "left",
                                  },
                                },
                                {
                                  id: "roomMeta",
                                  type: "Text",
                                  width: "fill",
                                  text: "Host: {{hostName}} | {{currentPlayers}}/{{maxPlayers}} players",
                                  styles: {
                                    fontSize: 14,
                                    opacity: "0.7",
                                    textAlign: "left",
                                  },
                                },
                              ],
                            },
                            {
                              id: "join",
                              $ref: "SecondaryButton",
                              width: 80,
                              height: 35,
                              props: {
                                label: "Join",
                              },
                              styles: { fontSize: 14, border: "1px solid rgba(255,255,255,0.5)" },
                              events: { click: "joinRoom" },
                            },
                          ],
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "browseButtons",
                  type: "HStack",
                  spacing: 20,
                  alignItems: "Center",
                  children: [
                    {
                      id: "refresh",
                      $ref: "SecondaryButton",
                      width: 140,
                      height: 40,
                      props: {
                        label: "Refresh",
                      },
                      styles: { fontSize: 16 },
                      events: { click: "refreshRooms" },
                    },
                    {
                      id: "back",
                      $ref: "SecondaryButton",
                      width: 140,
                      height: 40,
                      props: {
                        label: "Back",
                      },
                      styles: { fontSize: 16 },
                      events: { click: "showMainMenu" },
                    },
                  ],
                },
              ],
            },
            portrait: {
              type: "VStack",
              anchor: "Center",
              width: 900,
              spacing: 24,
              alignItems: "Center",
              children: [
                {
                  id: "title",
                  type: "Text",
                  text: "Join Online Game",
                  width: "fill",
                  styles: {
                    fontSize: 56,
                    textAlign: "center",
                  },
                },
                {
                  id: "emptyState",
                  $if: "roomList.length === 0",
                  then: {
                    type: "Text",
                    width: "fill",
                    text: "No active rooms found. Be the first to host!",
                    styles: {
                      fontSize: 28,
                      opacity: "0.5",
                      textAlign: "center",
                    },
                  },
                },
                {
                  id: "peerJoinCode",
                  $if: "isPeerLobby",
                  then: {
                    type: "HStack",
                    width: 860,
                    spacing: 20,
                    alignItems: "Center",
                    children: [
                      {
                        id: "codeInput",
                        type: "Input",
                        width: 560,
                        height: 60,
                        label: "Enter room code...",
                        value: "{{joinRoomCode}}",
                        focusable: true,
                        styles: {
                          padding: "14px",
                          fontSize: "24px",
                          borderColor: "white",
                          backgroundColor: "rgba(255,255,255,0.1)",
                          color: "white",
                        },
                        events: {
                          change: "joinRoomCodeChange",
                          submit: "submitJoinRoomCode",
                        },
                      },
                      {
                        id: "joinByCode",
                        $ref: "SecondaryButton",
                        width: 280,
                        height: 60,
                        props: {
                          label: "Join By Code",
                        },
                        styles: { fontSize: 24, border: "1px solid rgba(255,255,255,0.5)" },
                        events: { click: "submitJoinRoomCode" },
                      },
                    ],
                  },
                },
                {
                  id: "rooms",
                  type: "VStack",
                  width: 860,
                  spacing: 14,
                  alignItems: "Center",
                  children: [
                    {
                      id: "roomItems",
                      $each: "roomList",
                      content: [
                        {
                          id: "room",
                          type: "HStack",
                          width: 860,
                          height: 80,
                          justifyContent: "SpaceBetween",
                          alignItems: "Center",
                          styles: {
                            borderBottom: "1px solid rgba(255,255,255,0.2)",
                          },
                          children: [
                            {
                              id: "roomInfo",
                              type: "VStack",
                              width: 660,
                              spacing: 6,
                              children: [
                                {
                                  id: "roomName",
                                  type: "Text",
                                  width: "fill",
                                  text: "{{roomName}}",
                                  styles: {
                                    fontSize: 28,
                                    textAlign: "left",
                                  },
                                },
                                {
                                  id: "roomMeta",
                                  type: "Text",
                                  width: "fill",
                                  text: "Host: {{hostName}} | {{currentPlayers}}/{{maxPlayers}} players",
                                  styles: {
                                    fontSize: 22,
                                    opacity: "0.7",
                                    textAlign: "left",
                                  },
                                },
                              ],
                            },
                            {
                              id: "join",
                              $ref: "SecondaryButton",
                              width: 140,
                              height: 50,
                              props: {
                                label: "Join",
                              },
                              styles: { fontSize: 22, border: "1px solid rgba(255,255,255,0.5)" },
                              events: { click: "joinRoom" },
                            },
                          ],
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "browseButtons",
                  type: "HStack",
                  spacing: 30,
                  alignItems: "Center",
                  children: [
                    {
                      id: "refresh",
                      $ref: "SecondaryButton",
                      width: 240,
                      height: 60,
                      props: {
                        label: "Refresh",
                      },
                      styles: { fontSize: 26 },
                      events: { click: "refreshRooms" },
                    },
                    {
                      id: "back",
                      $ref: "SecondaryButton",
                      width: 240,
                      height: 60,
                      props: {
                        label: "Back",
                      },
                      styles: { fontSize: 26 },
                      events: { click: "showMainMenu" },
                    },
                  ],
                },
              ],
            },
          },
        },
      },
      {
        id: "lobby",
        $if: "step === 'LOBBY' && lobbyState",
        then: {
          $breakpoint: {
            landscape: {
              type: "HStack",
              anchor: "Center",
              width: 920,
              spacing: 40,
              alignItems: "Start",
              children: [
                {
                  id: "leftColumn",
                  type: "VStack",
                  width: 420,
                  spacing: 12,
                  children: [
                    {
                      id: "roomName",
                      type: "Text",
                      width: "fill",
                      text: "Room: {{lobbyState.roomName}}",
                      styles: { fontSize: 28, textAlign: "left" },
                    },
                    {
                      id: "roomId",
                      type: "Text",
                      width: "fill",
                      text: "Room ID: {{roomId}}",
                      styles: { fontSize: 14, opacity: "0.7", textAlign: "left" },
                    },
                    {
                      id: "sharePanel",
                      type: "HStack",
                      width: 400,
                      spacing: 12,
                      alignItems: "Center",
                      children: [
                        {
                          id: "roomUrl",
                          type: "Text",
                          width: 270,
                          text: "{{roomUrl}}",
                          styles: { fontSize: 11, opacity: "0.6", textAlign: "left" },
                        },
                        {
                          id: "copyLink",
                          $ref: "SecondaryButton",
                          width: 120,
                          height: 35,
                          props: {
                            label: "{{copyLinkLabel}}",
                          },
                          styles: { fontSize: 14, border: "1px solid rgba(255,255,255,0.5)" },
                          events: { click: "copyRoomLink" },
                        },
                      ],
                    },
                    {
                      id: "playersLabel",
                      type: "Text",
                      width: "fill",
                      text: "Players:",
                      styles: { fontSize: 20, textAlign: "left" },
                    },
                    {
                      id: "playersBox",
                      type: "Box",
                      width: 400,
                      height: 220,
                      styles: { border: "1px solid white", padding: "10px" },
                      children: [
                        {
                          id: "players",
                          type: "VStack",
                          anchor: "TopLeft",
                          offset: { x: 10, y: 10 },
                          width: 380,
                          spacing: 10,
                          children: [
                            {
                              id: "playerRows",
                              $each: "lobbyPlayers",
                              content: [
                                {
                                  id: "row",
                                  type: "HStack",
                                  width: 380,
                                  height: 24,
                                  spacing: 12,
                                  alignItems: "Center",
                                  children: [
                                    {
                                      id: "dot",
                                      type: "Box",
                                      width: 10,
                                      height: 10,
                                      styles: {
                                        borderRadius: "50%",
                                        backgroundColor: "{{readyColor}}",
                                      },
                                    },
                                    {
                                      id: "name",
                                      type: "Text",
                                      width: 320,
                                      text: "{{nameLabel}}",
                                      styles: { fontSize: 16, textAlign: "left" },
                                    },
                                  ],
                                },
                              ],
                            },
                          ],
                        },
                      ],
                    },
                    {
                      id: "ready",
                      $ref: "PrimaryButton",
                      width: 200,
                      height: 50,
                      props: {
                        label: "{{readyButtonLabel}}",
                      },
                      styles: {
                        fontSize: 16,
                        border: "2px solid rgba(255,255,255,0.8)",
                        backgroundColor: "{{readyButtonColor}}",
                      },
                      events: { click: "toggleReady" },
                    },
                    {
                      id: "start",
                      $if: "isHost",
                      then: {
                        $ref: "PrimaryButton",
                        width: 200,
                        height: 50,
                        props: {
                          label: "Start Game",
                        },
                        styles: { fontSize: 16, border: "2px solid rgba(255,255,255,0.8)", opacity: "{{startButtonOpacity}}" },
                        events: { click: "startOnlineGame" },
                      },
                    },
                    {
                      id: "leave",
                      $ref: "SecondaryButton",
                      width: 200,
                      height: 50,
                      props: {
                        label: "Leave Room",
                      },
                      styles: { fontSize: 16 },
                      events: { click: "leaveRoom" },
                    },
                  ],
                },
                {
                  id: "chatBox",
                  type: "VStack",
                  width: 400,
                  spacing: 0,
                  styles: { border: "1px solid white" },
                  children: [
                    {
                      id: "messages",
                      type: "Box",
                      width: 400,
                      height: 400,
                      styles: { overflow: "auto", padding: "10px", boxSizing: "border-box" },
                      children: [
                        {
                          id: "messageList",
                          type: "VStack",
                          width: "fill",
                          spacing: 8,
                          alignItems: "Start",
                          children: [
                            {
                              id: "messageItems",
                              $each: "chatMessages",
                              content: [
                                {
                                  id: "message",
                                  type: "Text",
                                  width: 380,
                                  text: "{{senderName}}: {{text}}",
                                  styles: { fontSize: 14, textAlign: "left" },
                                },
                              ],
                            },
                          ],
                        },
                      ],
                    },
                    {
                      id: "chatInputRow",
                      type: "HStack",
                      width: 400,
                      height: 40,
                      spacing: 0,
                      alignItems: "Center",
                      children: [
                        {
                          id: "input",
                          type: "Input",
                          width: "fill",
                          height: 40,
                          label: "Type a message...",
                          value: "{{chatDraft}}",
                          focusable: true,
                          styles: {
                            padding: "10px",
                            borderColor: "white",
                            backgroundColor: "rgba(255,255,255,0.1)",
                            color: "white",
                            borderTop: "1px solid white",
                          },
                          events: {
                            change: "chatChange",
                            submit: "chatSubmit",
                          },
                        },
                        {
                          id: "send",
                          $ref: "SecondaryButton",
                          width: 90,
                          height: 40,
                          props: {
                            label: "Send",
                          },
                          styles: { fontSize: 14, border: "1px solid rgba(255,255,255,0.5)", borderTop: "1px solid white" },
                          events: { click: "chatSend" },
                        },
                      ],
                    },
                  ],
                },
              ],
            },
            portrait: {
              type: "VStack",
              anchor: "Center",
              width: 900,
              spacing: 20,
              alignItems: "Center",
              children: [
                {
                  id: "roomName",
                  type: "Text",
                  width: "fill",
                  text: "Room: {{lobbyState.roomName}}",
                  styles: { fontSize: 40, textAlign: "center" },
                },
                {
                  id: "roomId",
                  type: "Text",
                  width: "fill",
                  text: "Room ID: {{roomId}}",
                  styles: { fontSize: 22, opacity: "0.7", textAlign: "center" },
                },
                {
                  id: "sharePanel",
                  type: "VStack",
                  width: 860,
                  spacing: 10,
                  alignItems: "Center",
                  children: [
                    {
                      id: "roomUrl",
                      type: "Text",
                      width: "fill",
                      text: "{{roomUrl}}",
                      styles: { fontSize: 16, opacity: "0.5", textAlign: "center" },
                    },
                    {
                      id: "copyLink",
                      $ref: "SecondaryButton",
                      width: 280,
                      height: 50,
                      props: {
                        label: "{{copyLinkLabel}}",
                      },
                      styles: { fontSize: 22, border: "1px solid rgba(255,255,255,0.5)" },
                      events: { click: "copyRoomLink" },
                    },
                  ],
                },
                {
                  id: "playersLabel",
                  type: "Text",
                  width: "fill",
                  text: "Players:",
                  styles: { fontSize: 32, textAlign: "center" },
                },
                {
                  id: "playersBox",
                  type: "Box",
                  width: 860,
                  height: 280,
                  styles: { border: "1px solid white", padding: "10px" },
                  children: [
                    {
                      id: "players",
                      type: "VStack",
                      anchor: "TopLeft",
                      offset: { x: 14, y: 14 },
                      width: 832,
                      spacing: 14,
                      children: [
                        {
                          id: "playerRows",
                          $each: "lobbyPlayers",
                          content: [
                            {
                              id: "row",
                              type: "HStack",
                              width: 832,
                              height: 32,
                              spacing: 16,
                              alignItems: "Center",
                              children: [
                                {
                                  id: "dot",
                                  type: "Box",
                                  width: 14,
                                  height: 14,
                                  styles: {
                                    borderRadius: "50%",
                                    backgroundColor: "{{readyColor}}",
                                  },
                                },
                                {
                                  id: "name",
                                  type: "Text",
                                  width: 780,
                                  text: "{{nameLabel}}",
                                  styles: { fontSize: 26, textAlign: "left" },
                                },
                              ],
                            },
                          ],
                        },
                      ],
                    },
                  ],
                },
                {
                  id: "lobbyButtons",
                  type: "HStack",
                  spacing: 20,
                  alignItems: "Center",
                  children: [
                    {
                      id: "ready",
                      $ref: "PrimaryButton",
                      width: 260,
                      height: 60,
                      props: {
                        label: "{{readyButtonLabel}}",
                      },
                      styles: {
                        fontSize: 24,
                        border: "2px solid rgba(255,255,255,0.8)",
                        backgroundColor: "{{readyButtonColor}}",
                      },
                      events: { click: "toggleReady" },
                    },
                    {
                      id: "start",
                      $if: "isHost",
                      then: {
                        $ref: "PrimaryButton",
                        width: 260,
                        height: 60,
                        props: {
                          label: "Start Game",
                        },
                        styles: { fontSize: 24, border: "2px solid rgba(255,255,255,0.8)", opacity: "{{startButtonOpacity}}" },
                        events: { click: "startOnlineGame" },
                      },
                    },
                    {
                      id: "leave",
                      $ref: "SecondaryButton",
                      width: 260,
                      height: 60,
                      props: {
                        label: "Leave Room",
                      },
                      styles: { fontSize: 24 },
                      events: { click: "leaveRoom" },
                    },
                  ],
                },
                {
                  id: "chatBox",
                  type: "VStack",
                  width: 860,
                  spacing: 0,
                  styles: { border: "1px solid white" },
                  children: [
                    {
                      id: "messages",
                      type: "Box",
                      width: 860,
                      height: 500,
                      styles: { overflow: "auto", padding: "10px", boxSizing: "border-box" },
                      children: [
                        {
                          id: "messageList",
                          type: "VStack",
                          width: "fill",
                          spacing: 10,
                          alignItems: "Start",
                          children: [
                            {
                              id: "messageItems",
                              $each: "chatMessages",
                              content: [
                                {
                                  id: "message",
                                  type: "Text",
                                  width: 832,
                                  text: "{{senderName}}: {{text}}",
                                  styles: { fontSize: 22, textAlign: "left" },
                                },
                              ],
                            },
                          ],
                        },
                      ],
                    },
                    {
                      id: "chatInputRow",
                      type: "HStack",
                      width: 860,
                      height: 60,
                      spacing: 0,
                      alignItems: "Center",
                      children: [
                        {
                          id: "input",
                          type: "Input",
                          width: "fill",
                          height: 60,
                          label: "Type a message...",
                          value: "{{chatDraft}}",
                          focusable: true,
                          styles: {
                            padding: "14px",
                            borderColor: "white",
                            backgroundColor: "rgba(255,255,255,0.1)",
                            color: "white",
                            borderTop: "1px solid white",
                          },
                          events: {
                            change: "chatChange",
                            submit: "chatSubmit",
                          },
                        },
                        {
                          id: "send",
                          $ref: "SecondaryButton",
                          width: 160,
                          height: 60,
                          props: {
                            label: "Send",
                          },
                          styles: { fontSize: 22, border: "1px solid rgba(255,255,255,0.5)", borderTop: "1px solid white" },
                          events: { click: "chatSend" },
                        },
                      ],
                    },
                  ],
                },
              ],
            },
          },
        },
      },
    ],
  },
}
